{
  "name": "pi-producthunt",
  "version": "0.1.4",
  "description": "Pi extension package for Product Hunt research and digest workflows.",
  "type": "module",
  "license": "MIT",
  "author": "eiei114",
  "keywords": [
    "pi-package",
    "pi",
    "producthunt",
    "research",
    "digest",
    "agent-skill",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-producthunt.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-producthunt/issues"
  },
  "homepage": "https://github.com/eiei114/pi-producthunt#readme",
  "files": [
    "extensions/",
    "lib/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "version:check": "node scripts/check-version-bump.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typebox": "latest",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
